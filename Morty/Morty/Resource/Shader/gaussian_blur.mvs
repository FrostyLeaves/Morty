#include "private_header.hlsl"

struct VS_IN_HDR
{
    float2 pos : POSITION;
};

struct VS_OUT_HDR
{
    float4 pos : SV_POSITION;
    float2 uv : TEXCOORD;
};

VS_OUT_HDR VS(VS_IN_HDR input)
{
    VS_OUT_HDR output;

    output.pos.xy = input.pos.xy;
    output.pos.w = 1.0f;
    output.pos.z = 0.0f;
    output.uv.x = output.pos.x * 0.5f + 0.5f;
    output.uv.y = 0.5f - output.pos.y * 0.5f;

    return output;
}
