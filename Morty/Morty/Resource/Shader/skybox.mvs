cbuffer cbSpace
{
    float4x4 MatWorld;
    float4x4 MatCamProj;
};

struct VS_IN
{
    float3 pos : POSITION;
};

struct VS_OUT
{
    float4 pos : SV_POSITION;
    float3 uvw : UVW;
};

VS_OUT VS(VS_IN input)
{
    VS_OUT output;

    output.pos = mul(float4(input.pos, 1.0f), mul(MatWorld, MatCamProj));
    output.pos.z = output.pos.w;

    output.uvw = input.pos;

    return output;
}
