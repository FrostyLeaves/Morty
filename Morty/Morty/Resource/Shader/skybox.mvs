#include "privateHeader.hlsl"

cbuffer _M_E_cbSpace
{
    float4x4 MatWorld;
    float4x4 MatCamProj;
};

struct VS_IN_SKYBOX
{
    float3 pos : POSITION;
};

struct VS_OUT_SKYBOX
{
    float4 pos : SV_POSITION;
    float3 uvw : UVW;
};

VS_OUT_SKYBOX VS(VS_IN_SKYBOX input)
{
    VS_OUT_SKYBOX output;

    output.pos = mul(float4(input.pos, 1.0f), mul(MatWorld, MatCamProj));
    output.pos.z = output.pos.w;

    output.uvw = input.pos;

    return output;
}
